{
  "name": "aliencharts",
  "version": "0.1.2",
  "description": "WebGL chart renderer for multi-metric dashboards, built for ease of use and high performance.",
  "type": "module",
  "license": "MIT",
  "author": "FarangLab",
  "keywords": [
    "charts",
    "chart-grid",
    "webgl",
    "react",
    "dashboard",
    "visualization",
    "data-visualization"
  ],
  "homepage": "https://github.com/FarangLab/aliencharts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FarangLab/aliencharts.git"
  },
  "bugs": {
    "url": "https://github.com/FarangLab/aliencharts/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/aliencharts.css"
  },
  "files": [
    "dist",
    "assets",
    "index.d.ts"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "node build.js && tailwindcss -i src/styles.css -o dist/aliencharts.css --minify",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.3.2"
  }
}
